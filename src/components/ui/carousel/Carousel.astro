---
import type { LogoItem } from '../../../data/logos';

interface Props {
  tools: LogoItem[];
  speedMs?: number;
}

const { tools = [], speedMs = 83000 } = Astro.props as Props;
---

<div class="carousel-wrapper overflow-hidden relative z-10 mx-auto px-8 py-4">
  <div class="[mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
    <div
      class="carousel-track flex w-max translate-x-0"
      style={`animation-duration: ${speedMs}ms;`}
      ontouchstart="this.style.animationPlayState='paused'"
      ontouchend="this.style.animationPlayState='running'"
      ontouchcancel="this.style.animationPlayState='running'"
    >
      {[...tools, ...tools].map((tool) => (
        <div class="group flex flex-col items-center justify-center px-6 py-7 mx-4 min-w-[160px] md:min-w-[180px] rounded-lg">
          <div class="w-10 h-10 mb-2 flex items-center justify-center">
            <span
              class="inline-flex w-10 h-10 items-center justify-center transition duration-300 group-hover:scale-110 text-[color:var(--color-text-muted)] group-hover:text-[color:var(--accent)]"
              aria-hidden="true"
              set:html={tool.icon}
            />
          </div>

          <span class="text-sm font-semibold text-[color:var(--color-text-muted)] transition-colors">
            {tool.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
.carousel-track {
  animation-name: carousel-scroll;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-play-state: running;
  will-change: transform;
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
}

.carousel-wrapper:hover .carousel-track {
  animation-play-state: paused;
}

@keyframes carousel-scroll {
  0% {
    transform: translate3d(-20%, 0, 0);
  }
  100% {
    transform: translate3d(-70%, 0, 0);
  }
}
</style>