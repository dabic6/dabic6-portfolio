---
import Button from "../ui/button/Button.astro";
import { projects } from "../../data/projects";

interface Props {
  title?: string;
}

const { title } = Astro.props as Props;
---

<section class="w-full py-10">
  <div class="mx-auto max-w-6xl px-4">
    {title && (
      <h2 class="text-3xl md:text-4xl font-semibold text-center mb-8 text-foreground">
        {title}
      </h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <article class="card-surface p-6 relative h-full flex flex-col">
          <h3 class="text-2xl font-semibold text-foreground leading-tight m-0 pr-2">
            {p.title}
          </h3>

          <p class="text-sm text-[color:var(--color-text-muted)] mt-2 mb-5">
            {p.techStack}
          </p>

          <div class="space-y-4">
            <div class="rounded-xl border border-white/8 bg-white/3 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent)] mb-2">
                Problem
              </p>
              <p class="text-[color:var(--color-text-secondary)] leading-relaxed m-0">
                {p.problem}
              </p>
            </div>

            <div class="rounded-xl border border-white/8 bg-white/3 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent)] mb-2">
                Solution
              </p>
              <p class="text-[color:var(--color-text-secondary)] leading-relaxed m-0">
                {p.solution}
              </p>
            </div>

            <div class="rounded-xl border border-white/8 bg-white/3 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent)] mb-2">
                Result
              </p>
              <p class="text-[color:var(--color-text-secondary)] leading-relaxed m-0">
                {p.result}
              </p>
            </div>
          </div>

          <div class="mt-6 flex justify-center">
            <Button href={p.ctaLink} variant="primary" size="sm">
              {p.ctaText}
            </Button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
